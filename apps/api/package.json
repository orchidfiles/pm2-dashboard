{
	"name": "@pm2-dashboard/api",
	"type": "module",
	"scripts": {
		"start": "node -r source-map-support/register dist/main.js",
		"build": "pnpm run build:compile && pnpm run build:postbuild",
		"build:watch": "tsc-watch -p tsconfig.build.json --onCompilationComplete \"pnpm run build:postbuild\"",
		"build:compile": "tsc -p tsconfig.build.json",
		"build:postbuild": "tsc-alias -p tsconfig.build.json && node node_modules/@pm2-dashboard/dev-kit/src/fix-esm-imports.mjs dist",
		"lint": "eslint src/",
		"lint:fix": "eslint src/ --fix",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"dependencies": {
		"@nestjs/common": "~11.1.0",
		"@nestjs/core": "~11.1.0",
		"@nestjs/platform-express": "~11.1.0",
		"@pm2-dashboard/shared": "workspace:*",
		"@types/bcryptjs": "~3.0.0",
		"@types/express-session": "~1.18.2",
		"bcryptjs": "~3.0.3",
		"better-sqlite3": "~11.9.1",
		"class-transformer": "~0.5.1",
		"class-validator": "~0.14.1",
		"date-fns": "~4.1.0",
		"drizzle-orm": "~0.43.1",
		"express-session": "~1.19.0",
		"pm2": "~6.0.5",
		"reflect-metadata": "~0.2.2",
		"rxjs": "~7.8.2",
		"source-map-support": "~0.5.21",
		"tslib": "~2.8.1"
	},
	"devDependencies": {
		"@nestjs/testing": "~11.1.16",
		"@pm2-dashboard/dev-kit": "workspace:*",
		"@swc/core": "~1.15.18",
		"@types/better-sqlite3": "~7.6.13",
		"@types/express": "~5.0.1",
		"@types/node": "~22.0.0",
		"@types/supertest": "~7.2.0",
		"drizzle-kit": "~0.31.9",
		"supertest": "~7.2.2",
		"tsc-alias": "~1.8.16",
		"tsc-watch": "~6.2.1",
		"typescript": "~5.7.0",
		"vite": "~8.0.0",
		"vite-plugin-swc-transform": "~1.1.1",
		"vite-tsconfig-paths": "~5.1.4",
		"vitest": "~4.0.18"
	}
}
