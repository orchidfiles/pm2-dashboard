{
  "name": "pm2-dashboard",
  "version": "0.2.0",
  "description": "Self-hosted web dashboard for PM2. Open source alternative to PM2 Plus. Authentication, process management, no cloud required.",
  "keywords": [
    "pm2",
    "dashboard",
    "web-ui",
    "monitoring",
    "self-hosted",
    "logs",
    "metrics"
  ],
  "homepage": "https://github.com/orchidfiles/pm2-dashboard#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/orchidfiles/pm2-dashboard"
  },
  "bugs": {
    "url": "https://github.com/orchidfiles/pm2-dashboard/issues"
  },
  "license": "MIT",
  "author": {
    "name": "orchidfiles",
    "email": "orchid@orchidfiles.com",
    "url": "https://orchidfiles.com"
  },
  "preferGlobal": true,
  "type": "module",
  "bin": {
    "pm2-dashboard": "./bin/pm2-dashboard.js"
  },
  "files": [
    "bin/",
    "dist/"
  ],
  "scripts": {
    "start": "node bin/pm2-dashboard.js",
    "release": "npm publish --access public"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@nestjs/common": "11.1.0",
    "@nestjs/core": "11.1.0",
    "@nestjs/platform-express": "11.1.0",
    "bcryptjs": "3.0.3",
    "better-sqlite3": "11.9.1",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.1",
    "commander": "14.0.3",
    "date-fns": "4.1.0",
    "drizzle-orm": "0.43.1",
    "express": "5.1.0",
    "express-session": "1.19.0",
    "pm2": "6.0.14",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "tslib": "2.8.1"
  }
}
