{
	"name": "@pm2-dashboard/shared",
	"type": "module",
	"exports": {
		".": {
			"import": "./lib/index.js",
			"types": "./lib/index.d.ts"
		}
	},
	"files": [
		"lib"
	],
	"scripts": {
		"build": "pnpm run clean && tsc -p tsconfig.build.json && pnpm run build:postbuild",
		"build:watch": "tsc-watch -p tsconfig.build.json --onCompilationComplete \"pnpm run build:postbuild\"",
		"build:compile": "tsc -p tsconfig.build.json",
		"build:postbuild": "tsc-alias -p tsconfig.build.json && node node_modules/@pm2-dashboard/dev-kit/src/fix-esm-imports.mjs lib",
		"clean": "rm -rf lib",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix"
	},
	"dependencies": {
		"dotenv": "~17.3.1"
	},
	"devDependencies": {
		"@pm2-dashboard/dev-kit": "workspace:*",
		"tsc-alias": "~1.8.16",
		"tsc-watch": "~6.2.1",
		"typescript": "~5.7.0"
	}
}
